# GigaChat credentials
GIGACHAT_AUTH_KEY=
GIGACHAT_RQUID=

# Optional: путь к CA-сертификату Сбера (по умолчанию используется системное хранилище)
# GIGACHAT_CA_CERT=/path/to/sber-ca.pem

# Admin upload protection (optional but recommended)
ADMIN_UPLOAD_TOKEN=change_me

# OCR and ingestion settings
ENABLE_OCR=true
OCR_LANG=rus+eng
MAX_UPLOAD_SIZE_MB=25
MAX_UPLOAD_FILES=20

# Retrieval settings
SEARCH_TOP_K=4
HYBRID_ALPHA=0.7

# Keyword search limit (защита от OOM при больших коллекциях)
KEYWORD_SEARCH_LIMIT=2000

# Cache settings
CACHE_TTL_DAYS=7

# Embeddings fallback (включить только если embeddings API нестабилен)
EMBEDDINGS_FALLBACK=false

# CORS (comma-separated)
ALLOWED_ORIGINS=https://avtoritet34.ru,https://www.avtoritet34.ru,http://localhost:5500,http://127.0.0.1:5500
